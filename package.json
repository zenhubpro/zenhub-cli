{
  "name": "zenhub-cli",
  "version": "0.1.0",
  "description": "CLI agent-native para ZenHub — automatize campanhas, grupos, agendamentos e ZenChat via terminal ou IA",
  "bin": {
    "zenhub": "./dist/index.js",
    "zenhub-cli": "./dist/index.js",
    "zenhub-mcp": "./dist/mcp/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
