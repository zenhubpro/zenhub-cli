{
  "name": "zenhub-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "ZenHub CLI + MCP monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "npm run lint --workspaces --if-present",
    "gen:openapi": "npm run gen --workspace @zenhub/tools",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
