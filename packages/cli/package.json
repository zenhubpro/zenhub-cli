{
  "name": "@zenhubpro/cli",
  "version": "0.1.0",
  "description": "ZenHub CLI — automate WhatsApp campaigns, schedules, groups, and ZenChat from terminal or AI agents",
  "bin": {
    "zenhub": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["zenhub", "whatsapp", "cli", "automation", "ai", "agent"],
  "dependencies": {
    "@zenhubpro/client": "0.1.0",
    "@zenhubpro/tools": "0.1.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.0"
  },
  "engines": { "node": ">=18" },
  "license": "MIT"
}
